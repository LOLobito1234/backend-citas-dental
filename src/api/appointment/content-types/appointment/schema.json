{
  "kind": "collectionType",
  "collectionName": "appointments",
  "info": {
    "singularName": "appointment",
    "pluralName": "appointments",
    "displayName": "Appointment"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string"
    },
    "telefono": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "fecha_hora": {
      "type": "datetime"
    },
    "estado": {
      "type": "enumeration",
      "default": "Pendiente",
      "enum": [
        "Pendiente",
        "Confirmada",
        "Cancelada"
      ]
    },
    "doctors": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::doctor.doctor",
      "mappedBy": "appointment"
    },
    "service": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::service.service",
      "inversedBy": "appointments"
    }
  }
}
